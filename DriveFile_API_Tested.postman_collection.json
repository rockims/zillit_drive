      "name": "Create File (Root Directory)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"File created successfully\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(1);",
              "    pm.expect(jsonData.message).to.eql('file_created');",
              "});",
              "",
              "// Store file ID for later use",
              "if (pm.response.json().data && pm.response.json().data._id) {",
              "    pm.collectionVariables.set(\"fileId\", pm.response.json().data._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "moduleData",
            "value": "{{moduleData}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"file_name\": \"document.pdf\",\n  \"description\": \"Important PDF document\",\n  \"file_type\": \"document\",\n  \"mime_type\": \"application/pdf\",\n  \"file_size\": \"1024 KB\",\n  \"file_size_bytes\": 1048576,\n  \"attachment\": {\n    \"url\": \"https://example.com/documents/doc.pdf\",\n    \"original_name\": \"document.pdf\",\n    \"size\": 1048576,\n    \"mime_type\": \"application/pdf\"\n  }\n}"
