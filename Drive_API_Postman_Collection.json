{
  "info": {
    "name": "Zillit Drive API Collection",
    "description": "Complete API collection for Zillit Drive folder and file management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8105",
      "type": "string"
    },
    {
      "key": "moduleData",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "moduleData",
            "value": "{{moduleData}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v2/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v2", "health"]
        }
      },
      "response": []
    },
    {
      "name": "Drive Folders",
      "item": [
        {
          "name": "Create Folder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder_name\": \"My Documents\",\n  \"description\": \"Personal documents folder\",\n  \"parent_folder_id\": null,\n  \"project_id\": \"PROJECT_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders"]
            }
          },
          "response": []
        },
        {
          "name": "Create Subfolder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder_name\": \"Reports\",\n  \"description\": \"Monthly reports subfolder\",\n  \"parent_folder_id\": \"FOLDER_ID_HERE\",\n  \"project_id\": \"PROJECT_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders"]
            }
          },
          "response": []
        },
        {
          "name": "Create File (via Folder with Attachments)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder_name\": \"Document.pdf\",\n  \"description\": \"Important PDF document\",\n  \"parent_folder_id\": \"FOLDER_ID_HERE\",\n  \"project_id\": \"PROJECT_ID_HERE\",\n  \"attachments\": [\n    {\n      \"media\": \"https://example.com/document.pdf\",\n      \"name\": \"Document.pdf\",\n      \"content_type\": \"document\",\n      \"content_subtype\": \"pdf\",\n      \"file_size\": \"1024000\",\n      \"bucket\": \"my-bucket\",\n      \"region\": \"us-east-1\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Folders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders"]
            }
          },
          "response": []
        },
        {
          "name": "Get Folder by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders/:folderId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders", ":folderId"],
              "variable": [
                {
                  "key": "folderId",
                  "value": "FOLDER_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Folder",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder_name\": \"Updated Folder Name\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders/:folderId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders", ":folderId"],
              "variable": [
                {
                  "key": "folderId",
                  "value": "FOLDER_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Folder",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/folders/:folderId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "folders", ":folderId"],
              "variable": [
                {
                  "key": "folderId",
                  "value": "FOLDER_ID_HERE"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Drive Files",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "name",
                  "value": "document.pdf",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Important document",
                  "type": "text"
                },
                {
                  "key": "folder",
                  "value": "FOLDER_ID_HERE",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files"]
            }
          },
          "response": []
        },
        {
          "name": "Create File (JSON data)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"notes.txt\",\n  \"description\": \"Personal notes file\",\n  \"folder\": \"FOLDER_ID_HERE\",\n  \"mimeType\": \"text/plain\",\n  \"size\": 1024\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files"]
            }
          },
          "response": []
        },
        {
          "name": "Get Files by Folder",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files?folder=FOLDER_ID_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files"],
              "query": [
                {
                  "key": "folder",
                  "value": "FOLDER_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get File by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files/:fileId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files", ":fileId"],
              "variable": [
                {
                  "key": "fileId",
                  "value": "FILE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update File",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"updated-filename.pdf\",\n  \"description\": \"Updated file description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files/:fileId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files", ":fileId"],
              "variable": [
                {
                  "key": "fileId",
                  "value": "FILE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Move File to Folder",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder\": \"NEW_FOLDER_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files/:fileId/move",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files", ":fileId", "move"],
              "variable": [
                {
                  "key": "fileId",
                  "value": "FILE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/drive/files/:fileId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "drive", "files", ":fileId"],
              "variable": [
                {
                  "key": "fileId",
                  "value": "FILE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ]
}
