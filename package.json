    "@signpdf/signer-p12": "^3.2.4",
    "@signpdf/signpdf": "^3.2.5",
    "archiver": "^7.0.1",
    "axios": "^1.5.1",
    "body-parser": "^1.20.2",
    "box-node-sdk": "^3.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "helmet": "^7.0.0",
    "joi-oid": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "morgan-json": "^1.1.0",
    "node-cron": "^3.0.3",
