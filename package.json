{
  "name": "zillit-drive",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test mocha --require @babel/register",
    "clean": "rimraf ./dist/",
    "eslint": "eslint src --fix",
    "build": "npm run clean && babel --env-name prod src -d dist --copy-files",
    "build:dev": "npm run clean && BABEL_ENV=dev babel src -d dist --copy-files",
    "start": "npm run build && node dist/index.js",
    "start:dev": "cross-env NODE_ENV=dev npm run build:dev && cross-env NODE_ENV=dev node dist/index.js",
    "local": "cross-env BABEL_ENV=dev NODE_ENV=dev babel-watch src/index.js",
    "dev": "cross-env NODE_ENV=dev nodemon --watch src --exec npm run start:dev",
    "outdated-packages": "npm outdated",
    "update-package": "ncu -u",
    "backfill:drive-access": "cross-env BABEL_ENV=dev babel-node src/scripts/backfillDriveFolderAccess.js"
  },
  "nyc": {
    "include": "src",
    "exclude": "**/*.test.js"
  },
  "keywords": [],
  "author": "Aviral Singh Pal",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.421.0",
