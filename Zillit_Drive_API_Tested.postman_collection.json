    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains process_id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('process_id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "moduleData",
            "value": "{{moduleData}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v2/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v2", "health"]
        }
      },
      "response": [
        {
          "name": "Health Check Success",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "moduleData",
                "value": "",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8105/api/v2/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8105",
              "path": ["api", "v2", "health"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [],
          "cookie": [],
          "body": "{\"message\":\"V1 Ok\",\"data\":{\"process_id\":46244,\"uptime\":19.6279015}}"
        }
      ]
