    {
      "name": "Drive Folders",
      "item": [
        {
          "name": "Create Root Folder",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Folder created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(1);",
                  "    pm.expect(jsonData.message).to.eql('folder_created');",
                  "});",
                  "",
                  "// Store folder ID for later use",
                  "if (pm.response.json().data && pm.response.json().data._id) {",
                  "    pm.collectionVariables.set(\"folderId\", pm.response.json().data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "moduleData",
                "value": "{{moduleData}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folder_name\": \"My Documents\",\n  \"description\": \"Personal documents folder\"\n}"
            },
